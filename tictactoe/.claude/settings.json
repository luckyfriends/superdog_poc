{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read",
      "Edit(tictactoe.html)",
      "Edit(.claude/**)",
      "Bash(open *)",
      "Bash(git *)",
      "Bash(ls *)",
      "Bash(cat *)"
    ],
    "deny": [
      "Bash(rm -rf *)"
    ],
    "defaultMode": "default"
  },
  "cleanupPeriodDays": 30,
  "respectGitignore": true
}
